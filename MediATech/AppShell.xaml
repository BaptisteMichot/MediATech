<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MediATech.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:view="clr-namespace:MediATech.View"
    Shell.FlyoutBehavior="Disabled"
    Title="MediATech">

    <ShellContent
        ContentTemplate="{DataTemplate view:MainPage}"
        Route="MainPage" />

    <ShellContent
        ContentTemplate="{DataTemplate view:LoginPage}"
        Route="LoginPage" />

    <ShellContent
        ContentTemplate="{DataTemplate view:RegisterPage}"
        Route="RegisterPage" />

    <ShellContent
        ContentTemplate="{DataTemplate view:PasswordPage}"
        Route="PasswordPage" />

    <ShellContent
        ContentTemplate="{DataTemplate view:BookingPage}"
        Route="BookingPage" />

</Shell>
